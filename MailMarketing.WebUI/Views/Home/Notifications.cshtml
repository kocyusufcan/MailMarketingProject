@model List<MailMarketing.Entity.Notification>
@{
    ViewData["Title"] = "Bildirimlerim";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold text-primary mb-0"><i class="fas fa-bell me-2"></i> Bildirim Geçmişi</h2>
            <small class="text-muted" id="totalCountDisplay">Toplam @ViewBag.TotalCount bildirim kayıtlı</small>
        </div>
        <div id="bulkActions" style="display: none;">
            <button class="btn btn-danger btn-sm rounded-pill shadow-sm px-3" onclick="deleteSelected()">
                <i class="fas fa-trash-alt me-1"></i> Seçilenleri Sil (<span id="selectedCount">0</span>)
            </button>
        </div>
    </div>

    <div class="card shadow-sm border-0">
        @if (Model.Any())
        {
            <div class="card-header bg-white py-3 border-bottom d-flex align-items-center">
                <div class="form-check">
                    <input class="form-check-input" type="checkbox" id="selectAll">
                    <label class="form-check-label fw-bold ms-2 text-secondary" for="selectAll" style="cursor:pointer;">Tümünü Seç</label>
                </div>
            </div>
        }
        
        <div class="list-group list-group-flush" id="notificationList">
            @if (Model.Count == 0)
            {
                <div class="text-center py-5">
                    <i class="fas fa-check-circle fa-3x text-success mb-3 opacity-50"></i>
                    <p class="lead text-muted">Hiç bildiriminiz yok, her şey yolunda!</p>
                </div>
            }
            else
            {
                @foreach (var item in Model)
                {
                    <div class="list-group-item list-group-item-action p-3 d-flex align-items-center notification-item" id="notif-@item.Id">
                        <div class="form-check me-3">
                            <input class="form-check-input select-item" type="checkbox" value="@item.Id">
                        </div>
                        <div class="ms-2 me-auto">
                            <h6 class="mb-1 fw-bold @(item.IsRead ? "text-dark" : "text-danger")">
                                @if(!item.IsRead) { <span class="badge bg-danger p-1 me-1" style="font-size: 6px; vertical-align: middle;"> </span> }
                                @item.Title
                            </h6>
                            <p class="mb-0 text-muted small">@item.Message</p>
                            <small class="text-secondary" style="font-size: 0.75rem;">
                                <i class="far fa-clock me-1"></i> @item.CreatedAt.ToString("dd.MM.yyyy HH:mm")
                            </small>
                        </div>
                        <button class="btn btn-link text-muted btn-sm opacity-50 hover-danger" onclick="deleteNotification(@item.Id)">
                            <i class="fas fa-times"></i>
                        </button>
                    </div>
                }
            }
        </div>
    </div>

    @* --- 🔥 AKILLI SAYFALAMA BUTONLARI (Pagination) --- *@
    @if (ViewBag.TotalPages > 1)
    {
        <nav aria-label="Page navigation" class="mt-4 mb-5">
            <ul class="pagination justify-content-center shadow-sm">
                @{
                    int cur = ViewBag.CurrentPage;
                    int total = ViewBag.TotalPages;
                    int gap = 2; // Aktif sayfanın sağında ve solunda kaç buton görünsün?
                }

                @* ⬅️ Geri *@
                <li class="page-item @(cur == 1 ? "disabled" : "")">
                    <a class="page-link" href="@Url.Action("Notifications", new { page = cur - 1 })" aria-label="Previous">
                        <span aria-hidden="true">&laquo;</span>
                    </a>
                </li>

                @* 1️⃣ İlk Sayfa *@
                <li class="page-item @(cur == 1 ? "active" : "")">
                    <a class="page-link" href="@Url.Action("Notifications", new { page = 1 })">1</a>
                </li>

                @* 🔍 Sol Üç Nokta *@
                @if (cur - gap > 2)
                {
                    <li class="page-item disabled"><span class="page-link border-0 bg-transparent text-muted">...</span></li>
                }

                @* 🔢 Ortadaki Dinamik Sayılar *@
                @for (int i = Math.Max(2, cur - gap); i <= Math.Min(total - 1, cur + gap); i++)
                {
                    <li class="page-item @(cur == i ? "active" : "")">
                        <a class="page-link" href="@Url.Action("Notifications", new { page = i })">@i</a>
                    </li>
                }

                @* 🔍 Sağ Üç Nokta *@
                @if (cur + gap < total - 1)
                {
                    <li class="page-item disabled"><span class="page-link border-0 bg-transparent text-muted">...</span></li>
                }

                @* 🏁 Son Sayfa *@
                <li class="page-item @(cur == total ? "active" : "")">
                    <a class="page-link" href="@Url.Action("Notifications", new { page = total })">@total</a>
                </li>

                @* ➡️ İleri *@
                <li class="page-item @(cur == total ? "disabled" : "")">
                    <a class="page-link" href="@Url.Action("Notifications", new { page = cur + 1 })" aria-label="Next">
                        <span aria-hidden="true">&raquo;</span>
                    </a>
                </li>
            </ul>
        </nav>
    }
</div>

@section Scripts {
    <script>
        // Checkbox yönetimi
        $(document).on('change', '.select-item, #selectAll', function() {
            if (this.id === 'selectAll') {
                $('.select-item').prop('checked', this.checked);
            }
            
            const count = $('.select-item:checked').length;
            if (count > 0) {
                $('#bulkActions').fadeIn(200);
                $('#selectedCount').text(count);
            } else {
                $('#bulkActions').fadeOut(200);
                $('#selectAll').prop('checked', false);
            }
        });

        // Toplu Silme (SweetAlert2)
        function deleteSelected() {
            const selectedIds = $('.select-item:checked').map(function() { return $(this).val(); }).get();
            
            Swal.fire({
                title: 'Emin misiniz?',
                text: selectedIds.length + " adet bildirim kalıcı olarak silinecek!",
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#d33',
                cancelButtonColor: '#3085d6',
                confirmButtonText: 'Evet, Hepsini Sil!',
                cancelButtonText: 'Vazgeç',
                background: '#fff',
                borderRadius: '15px'
            }).then((result) => {
                if (result.isConfirmed) {
                    $.post('/Home/DeleteBulkNotifications', { ids: selectedIds }, function() {
                        location.reload(); 
                    });
                }
            });
        }

        // Tekli Silme (SweetAlert2)
        function deleteNotification(id) {
            Swal.fire({
                title: 'Kaydı silmek istediğinize emin misiniz?',
                text: "Bu işlem geri alınamaz!",
                icon: 'question',
                showCancelButton: true,
                confirmButtonColor: '#d33',
                cancelButtonColor: '#6c757d',
                confirmButtonText: 'Sil',
                cancelButtonText: 'İptal'
            }).then((result) => {
                if (result.isConfirmed) {
                    $.post('/Home/DeleteNotification', { id: id }, function() {
                        $("#notif-" + id).fadeOut(300, function() { 
                            $(this).remove(); 
                            if($('.notification-item').length === 0) location.reload();
                        });
                        
                        const Toast = Swal.mixin({
                            toast: true,
                            position: 'top-end',
                            showConfirmButton: false,
                            timer: 2000,
                            timerProgressBar: true
                        });
                        Toast.fire({
                            icon: 'success',
                            title: 'Bildirim silindi'
                        });
                    });
                }
            });
        }
    </script>

    <style>
        .hover-danger:hover { color: #dc3545 !important; transition: 0.3s; }
        .notification-item { transition: background 0.2s; border-left: 3px solid transparent; }
        .notification-item:hover { background-color: #f8f9fa; border-left: 3px solid #0d6efd; }
        .form-check-input { cursor: pointer; }
        .pagination .page-link { color: #0d6efd; border-radius: 5px; margin: 0 2px; }
        .pagination .page-item.active .page-link { background-color: #0d6efd; border-color: #0d6efd; color: white !important; }
    </style>
}