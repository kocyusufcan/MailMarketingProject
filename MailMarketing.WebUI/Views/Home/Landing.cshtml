@model List<MailMarketing.Entity.User>
@{
    Layout = "_Layout"; 
    ViewData["Title"] = "Hoş Geldiniz";
}

@* --- 🔔 BİLDİRİM SİSTEMİ (SweetAlert2) --- *@
@if (TempData["Error"] != null)
{
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        document.addEventListener("DOMContentLoaded", function() {
            Swal.fire({
                icon: 'warning',
                title: 'Uyarı!',
                text: '@TempData["Error"]',
                confirmButtonColor: '#6366f1'
            });
        });
    </script>
}
@if (TempData["Message"] != null)
{
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        document.addEventListener("DOMContentLoaded", function() {
            Swal.fire({
                icon: 'success',
                title: 'Başarılı!',
                text: '@TempData["Message"]',
                timer: 3000,
                showConfirmButton: false
            });
        });
    </script>
}

<div class="container py-5">
    <div class="row align-items-center" style="min-height: 70vh;">
        <div class="col-md-6 text-center text-md-start">
            <h1 class="display-4 fw-bold text-primary mb-3">MailMarketing</h1>
            <p class="lead text-muted">
                Dijital dünyada bağlarınızı güçlendirin! En sevdiğiniz içerik üreticisinin bültenine abone olarak güncel kalmaya devam edin.
            </p>
            <img src="https://img.freepik.com/free-vector/email-marketing-internet-chatting-24-hours-support_335657-3009.jpg" 
                 alt="Marketing Illustration" class="img-fluid rounded shadow-sm mt-3" style="max-height: 300px;">
        </div>

        <div class="col-md-5 offset-md-1">
            <div class="card border-0 shadow-lg p-4 mt-4 mt-md-0" style="border-radius: 20px;">
                <div class="card-body">
                    
                    @* --- ADIM 2: ABONELİK DOĞRULAMA (KOD EKRANI) --- *@
                    @if (ViewBag.Step == 2)
                    {
                        <div class="text-center">
                            <h3 class="card-title mb-3 fw-bold">E-Postanı Doğrula</h3>
                            <div class="alert alert-info border-0 shadow-sm small mb-4" style="border-radius: 15px;">
                                <i class="fas fa-envelope-open-text fa-2x mb-2 d-block text-primary"></i>
                                <strong>@ViewBag.TargetEmail</strong> adresine bir kod gönderdik. Lütfen kontrol et.
                            </div>
                            
                            <form asp-action="VerifySubscription" method="post">
                                <div class="mb-4">
                                    <label class="form-label fw-bold text-muted small uppercase">6 HANELİ KOD</label>
                                    <input type="text" name="code" class="form-control form-control-lg text-center fw-bold" 
                                           placeholder="000000" maxlength="6" pattern="\d{6}" required 
                                           style="letter-spacing: 10px; border-radius: 12px; border: 2px solid #e2e8f0;">
                                </div>
                                <button type="submit" class="btn btn-success btn-lg w-100 shadow-sm rounded-pill fw-bold">
                                    <i class="fas fa-check-double me-2"></i> Aboneliği Onayla
                                </button>
                            </form>
                            
                            <div class="mt-3">
                                <a href="/" class="text-decoration-none small text-secondary">
                                    <i class="fas fa-arrow-left me-1"></i> Vazgeç ve Geri Dön
                                </a>
                            </div>
                        </div>
                    }
                    @* --- ADIM 1: ABONELİK FORMU (VİTRİN) --- *@
                    else
                    {
                        <h3 class="card-title mb-4 fw-bold text-dark">Bültene Katılın</h3>
                        <form asp-action="Subscribe" method="post">
                            <div class="row">
                                <div class="col-md-6 mb-3">
                                    <label class="form-label small fw-bold text-muted">ADINIZ</label>
                                    <input type="text" name="firstName" class="form-control rounded-3" placeholder="Adınız" required>
                                </div>
                                <div class="col-md-6 mb-3">
                                    <label class="form-label small fw-bold text-muted">SOYADINIZ</label>
                                    <input type="text" name="lastName" class="form-control rounded-3" placeholder="Soyadınız" required>
                                </div>
                            </div>

                            <div class="mb-3">
                                <label class="form-label small fw-bold text-muted">E-POSTA ADRESİNİZ</label>
                                <input type="email" name="email" class="form-control rounded-3" placeholder="ornek@mail.com" required>
                            </div>

                            <div class="mb-3">
                                <label class="form-label small fw-bold text-muted">BÜLTEN SEÇİNİZ</label>
                                <select name="targetUserId" class="form-select shadow-sm rounded-3" required>
                                    <option value="" selected disabled>Yayıncı seçiniz...</option>
                                    @if (Model != null)
                                    {
                                        foreach (var user in Model)
                                        {
                                            var gosterilecekAd = string.IsNullOrWhiteSpace(user.BrandName) 
                                                                 ? $"{user.FirstName} {user.LastName}" 
                                                                 : user.BrandName;
                                                                 
                                            <option value="@user.Id">@gosterilecekAd</option>
                                        }
                                    }
                                </select>
                            </div>

                            <button type="submit" class="btn btn-primary btn-lg w-100 shadow-sm mt-2 rounded-pill fw-bold">
                                <i class="fas fa-paper-plane me-2"></i> Hemen Abone Ol
                            </button>
                        </form>
                    }

                    <p class="text-muted small mt-4 text-center">
                        <i class="fas fa-user-shield me-1"></i> Bilgileriniz güvenle saklanır.
                    </p>
                </div>
            </div>
        </div>
    </div>
</div>