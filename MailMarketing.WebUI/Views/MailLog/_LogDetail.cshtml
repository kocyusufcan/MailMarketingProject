@model MailMarketing.Entity.MailLog

<div class="p-2">
    <div class="mb-3 border-bottom pb-2">
        <label class="fw-bold text-muted small">Alıcı Bilgisi</label>
        <div class="d-flex align-items-center">
            <i class="fas fa-user-circle fa-2x me-2 text-primary"></i>
            <div>
                <div class="fw-bold">@(Model.Subscriber?.FirstName) @(Model.Subscriber?.LastName)</div>
                <div class="text-muted small">@Model.Subscriber?.Email</div>
            </div>
        </div>
    </div>

    <div class="mb-3 border-bottom pb-2">
        <label class="fw-bold text-muted small">E-Posta Şablonu</label>
        <div><i class="fas fa-file-alt me-1 text-info"></i> @(Model.Template?.Title ?? "Sistem Mesajı")</div>
    </div>

    <div class="row mb-3">
        <div class="col-6">
            <label class="fw-bold text-muted small">Gönderim Tarihi</label>
            <div><i class="fas fa-calendar-day me-1"></i> @Model.SentDate.ToString("dd.MM.yyyy")</div>
            <div class="text-muted small"><i class="fas fa-clock me-1"></i> @Model.SentDate.ToString("HH:mm:ss")</div>
        </div>
        <div class="col-6">
            <label class="fw-bold text-muted small">Durum</label>
            <div>
                @if (Model.IsSuccess)
                {
                    <span class="badge bg-success"><i class="fas fa-check-circle me-1"></i> Başarıyla Gönderildi</span>
                }
                else
                {
                    <span class="badge bg-danger"><i class="fas fa-times-circle me-1"></i> Gönderim Başarısız</span>
                }
            </div>
        </div>
    </div>
    @if (!Model.IsSuccess && !string.IsNullOrEmpty(Model.ErrorMessage))
    {
        <div class="alert alert-danger border-0 shadow-sm mb-0">
            <label class="fw-bold small d-block mb-1"><i class="fas fa-bug me-1"></i> Hata Detayı:</label>
            <code class="small text-dark">@Model.ErrorMessage</code>
        </div>
    }
    else if (Model.IsSuccess)
    {
        <div class="alert alert-light border text-center mb-0 py-2">
            <i class="fas fa-info-circle text-muted me-1"></i> Bu işlem sorunsuz tamamlandı.
        </div>
    }
</div>