@{
    ViewData["Title"] = "Parola Hatırlatma";
    Layout = "_Layout";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-5">
            <div class="card shadow-lg border-0">
                <div class="card-header bg-warning text-dark text-center py-3">
                    <h4 class="mb-0"><i class="fas fa-key me-2"></i> Parola Hatırlatma</h4>
                </div>
                <div class="card-body p-4">

                    @if (ViewBag.Error != null)
                    {
                        <div class="alert alert-danger border-0 shadow-sm animate__animated animate__shakeX">
                            <i class="fas fa-exclamation-circle me-2"></i> @ViewBag.Error
                        </div>
                    }

                    @* --- ADIM 1: E-POSTA SORGULAMA --- *@
                    @if (ViewBag.Step == null || ViewBag.Step == 1)
                    {
                        <p class="text-muted small mb-4 text-center">Hesabınızı bulabilmemiz için sisteme kayıtlı e-posta adresinizi yazın.</p>
                        <form asp-action="ForgotPassword" method="post">
                            <div class="mb-3">
                                <label class="form-label fw-bold">E-Posta Adresiniz</label>
                                <div class="input-group">
                                    <span class="input-group-text bg-light"><i class="fas fa-envelope text-muted"></i></span>
                                    <input type="email" name="email" class="form-control" placeholder="ornek@mail.com" required>
                                </div>
                            </div>
                            <button type="submit" class="btn btn-primary w-100 py-2 shadow-sm">
                                <i class="fas fa-paper-plane me-2"></i> Doğrulama Kodu Gönder
                            </button>
                        </form>
                    }

                    @* --- ADIM 2: KOD DOĞRULAMA (GELİŞMİŞ TİMER EKLENDİ) --- *@
                    else if (ViewBag.Step == 2)
                    {
                        <div class="alert alert-info border-0 shadow-sm small text-center mb-4">
                            <i class="fas fa-info-circle me-2"></i> <b>@ViewBag.Email</b> adresine 6 haneli bir doğrulama kodu gönderdik. Lütfen kontrol edin.
                        </div>
                        <form asp-action="VerifyCode" method="post">
                            <input type="hidden" name="email" value="@ViewBag.Email" />
                            <div class="mb-3 text-center">
                                <label class="form-label fw-bold">Doğrulama Kodu</label>
                                @* 🔥 ID EKLENDİ: id="passCodeInput" *@
                                <input type="text" id="passCodeInput" name="code" class="form-control form-control-lg text-center fw-bold" 
                                       placeholder="000000" maxlength="6" pattern="\d{6}" required style="letter-spacing: 5px;">
                                <small class="text-muted">Lütfen sadece rakam girin.</small>
                            </div>

                            @* 🔥 TIMER VE YENİDEN GÖNDER ALANI *@
                            <div class="text-center mb-3">
                                <p id="timerText" class="text-muted small">
                                    Kalan Süre: <span id="countdown" class="fw-bold text-danger">01:00</span>
                                </p>
                                <div id="resendArea" style="display: none;">
                                    <p class="small text-muted mb-1">Kod gelmedi mi?</p>
                                    <button type="button" onclick="resendPassCode()" class="btn btn-link btn-sm text-primary fw-bold p-0 text-decoration-none">
                                        <i class="fas fa-redo me-1"></i> Yeni Kod Gönder
                                    </button>
                                </div>
                            </div>

                            @* 🔥 ID EKLENDİ: id="verifyBtn" *@
                            <button type="submit" id="verifyBtn" class="btn btn-warning w-100 py-2 text-white shadow-sm fw-bold">
                                <i class="fas fa-check-shield me-2"></i> Kodu Doğrula
                            </button>
                        </form>
                    }

                    @* --- ADIM 3: YENİ PAROLA BELİRLEME --- *@
                    else if (ViewBag.Step == 3)
                    {
                        <div class="alert alert-success border-0 shadow-sm small text-center mb-4">
                            <i class="fas fa-check-circle me-2"></i> Kimliğin doğrulandı! Şimdi yeni şifreni belirleyebilirsin.
                        </div>
                        <form asp-action="ResetPassword" method="post">
                            <input type="hidden" name="email" value="@ViewBag.Email" />
                            <div class="mb-3">
                                <label class="form-label fw-bold">Yeni Parolanız</label>
                                <div class="input-group">
                                    <span class="input-group-text bg-light"><i class="fas fa-lock text-muted"></i></span>
                                    <input type="password" name="newPassword" class="form-control" 
                                           placeholder="En az 8 karakter, Harf ve Rakam" required>
                                </div>
                            </div>
                            <div class="mb-4">
                                <label class="form-label fw-bold">Parola Tekrar</label>
                                <div class="input-group">
                                    <span class="input-group-text bg-light"><i class="fas fa-redo text-muted"></i></span>
                                    <input type="password" name="passwordConfirm" class="form-control" required>
                                </div>
                            </div>
                            <button type="submit" class="btn btn-success w-100 py-2 shadow-sm fw-bold">
                                <i class="fas fa-save me-2"></i> Parolayı Güncelle ve Giriş Yap
                            </button>
                        </form>
                    }

                    <div class="text-center mt-4 border-top pt-3">
                        <a asp-action="Login" class="text-decoration-none small text-secondary">
                            <i class="fas fa-arrow-left me-1"></i> Giriş sayfasına dön
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>

    <script>
        // 🔥 GÜÇLENDİRİLMİŞ TIMER MANTIĞI
        var timerInterval;
        
        // Backend'den gelen kalan süreyi alıyoruz.
        // Eğer backend TimerExpired=true gönderdiyse süre 0 kabul edilir.
        var isServerExpired = @((ViewBag.TimerExpired == true).ToString().ToLower());
        var serverRemainingTime = @(ViewBag.RemainingTime ?? 60);
        var timeLeft = serverRemainingTime;

        function startPassTimer() {
            clearInterval(timerInterval);
            
            var timerText = document.getElementById("timerText");
            var resendArea = document.getElementById("resendArea");
            var countdown = document.getElementById("countdown");
            var inputField = document.getElementById("passCodeInput");
            var verifyBtn = document.getElementById("verifyBtn");

            // Eğer sunucu "Süre bitti" dediyse veya kalan süre 0 ise
            if (isServerExpired || timeLeft <= 0) {
                expirePassSession();
                return;
            }

            // Normal Başlangıç
            if(inputField) inputField.disabled = false;
            if(verifyBtn) verifyBtn.disabled = false;
            if(timerText) timerText.style.display = "block";
            if(resendArea) resendArea.style.display = "none";

            timerInterval = setInterval(function() {
                timeLeft--;
                let m = Math.floor(timeLeft / 60);
                let s = timeLeft % 60;
                
                if(countdown) {
                    countdown.innerText = (m < 10 ? "0" + m : m) + ":" + (s < 10 ? "0" + s : s);
                }

                if (timeLeft <= 0) {
                    clearInterval(timerInterval);
                    expirePassSession();
                }
            }, 1000);
        }

        function expirePassSession() {
            var timerText = document.getElementById("timerText");
            var resendArea = document.getElementById("resendArea");
            var inputField = document.getElementById("passCodeInput");
            var verifyBtn = document.getElementById("verifyBtn");

            if(timerText) timerText.style.display = "none";
            if(resendArea) resendArea.style.display = "block";
            
            if(inputField) {
                inputField.value = ""; 
                inputField.disabled = true; 
                inputField.placeholder = "Süre Doldu!";
            }
            if(verifyBtn) verifyBtn.disabled = true;
        }

        // AJAX ile Yeni Kod İsteği
        function resendPassCode() {
            $.post("/Account/ResendForgotPasswordCode", function(r) {
                if(r.success) {
                    Swal.fire({
                        icon: 'success', title: 'Yeni kod gönderildi!',
                        text: 'Mail kutunuzu kontrol edin.', timer: 2000, showConfirmButton: false
                    });
                    
                    // Her şeyi sıfırla
                    timeLeft = 60;
                    isServerExpired = false;
                    
                    var inputField = document.getElementById("passCodeInput");
                    var verifyBtn = document.getElementById("verifyBtn");
                    
                    if(inputField) {
                        inputField.disabled = false;
                        inputField.value = "";
                        inputField.placeholder = "000000";
                        inputField.focus();
                    }
                    if(verifyBtn) verifyBtn.disabled = false;

                    startPassTimer();
                } else {
                    Swal.fire({ icon: 'error', title: 'Hata', text: r.message });
                }
            });
        }

        // Sayfa Yüklendiğinde
        $(document).ready(function() {
            // Eğer Step 2'deysek (Kod girme ekranı) sayacı başlat
            if (document.getElementById("passCodeInput")) {
                startPassTimer();
            }
        });
    </script>
}