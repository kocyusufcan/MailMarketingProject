@using MailMarketing.Entity
@model List<SubscriberGroup>
@{
    ViewData["Title"] = "Klasörlerim";
    var counts = ViewBag.GroupCounts as Dictionary<int, int> ?? new Dictionary<int, int>();
}

<style>
    :root { --folder-primary: #0d6efd; }

    /* 🔵 KART TASARIMI */
    .folder-card {
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        border-radius: 24px;
        cursor: pointer;
        border: 2px solid #edf2f7;
        background: #fff;
        position: relative;
        overflow: hidden;
    }

    .folder-card.is-selected {
        border-color: var(--folder-primary);
        background-color: #f0f7ff;
        box-shadow: 0 0 0 4px rgba(13, 110, 253, 0.1);
    }

    .folder-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 10px 20px rgba(0,0,0,0.05);
    }

    /* 📌 SİSTEM KLASÖRÜ (Tüm Aboneler) */
    .folder-card.is-system {
        border-color: #6f42c1;
        background: linear-gradient(135deg, #f8f5ff 0%, #ede9ff 100%);
    }
    .folder-card.is-system .folder-icon-wrapper {
        background: rgba(111, 66, 193, 0.1);
    }
    .folder-card.is-system .folder-icon {
        color: #6f42c1;
    }
    .folder-card.is-system:hover {
        box-shadow: 0 10px 25px rgba(111, 66, 193, 0.2);
    }
    .system-badge {
        font-size: 0.65rem;
        background: #6f42c1;
        color: white;
        border-radius: 20px;
        padding: 2px 8px;
        display: inline-flex;
        align-items: center;
        gap: 3px;
    }

    /* 🔘 CHECKBOX */
    .folder-checkbox-area {
        position: absolute;
        top: 20px;
        left: 20px;
        z-index: 10;
    }

    .folder-checkbox {
        width: 1.2rem;
        height: 1.2rem;
        border-radius: 6px;
        cursor: pointer;
    }

    /* 📂 İKONLAR */
    .folder-icon-wrapper {
        width: 70px;
        height: 70px;
        background: rgba(13, 110, 253, 0.05);
        border-radius: 18px;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 1rem;
        transition: all 0.3s ease;
    }
    .folder-card.is-selected .folder-icon-wrapper { background: var(--folder-primary); color: white; }
    .folder-icon { font-size: 2.2rem; color: var(--folder-primary); }
    .folder-card.is-selected .folder-icon { color: white; }

    /* 🗑️ ÜSTTEKİ SABİT SİLME BUTONU ALANI */
    #bulkActionHeader {
        display: none; /* Başta gizli */
        background: #fff;
        border: 2px solid #fee2e2;
        border-radius: 50px;
        padding: 5px 20px;
        animation: slideIn 0.3s ease;
    }

    @@keyframes slideIn {
        from { opacity: 0; transform: scale(0.9); }
        to { opacity: 1; transform: scale(1); }
    }
</style>

<div class="container mt-4">
    @* --- ÜST BAŞLIK VE AKILLI ARAÇ ÇUBUĞU --- *@
    <div class="d-flex justify-content-between align-items-center mb-5 flex-wrap gap-3">
        <div>
            <h2 class="fw-bold text-dark mb-1"><i class="fas fa-layer-group text-primary me-2"></i>Klasör Merkezi</h2>
            <p class="text-muted small mb-0">Klasörleri yönetmek veya içeriğini görmek için tıklayın.</p>
        </div>
        
        <div class="d-flex gap-3 align-items-center">
            @* 🔥 YENİ: SABİT TOPLU İŞLEM ALANI (Hader'da duracak) *@
            <div id="bulkActionHeader" class="d-none align-items-center gap-3 shadow-sm">
                <span class="text-danger fw-bold small"><span id="selectedFolderCount">0</span> Seçili</span>
                <div class="vr"></div>
                <button class="btn btn-sm btn-primary rounded-pill px-3 fw-bold" onclick="openAddMemberModal()">
                    <i class="fas fa-user-plus me-1"></i> Abone Ekle
                </button>
                <button class="btn btn-sm btn-danger rounded-pill px-3 fw-bold" onclick="bulkDeleteGroups()">
                    <i class="fas fa-trash-alt me-1"></i> Seçilenleri Sil
                </button>
                <button class="btn btn-sm btn-link text-muted text-decoration-none small" onclick="clearAllSelections()">Vazgeç</button>
            </div>

            @* Arama *@
            <form method="get" asp-action="Groups" class="input-group" style="width: 220px;">
                <input type="text" name="searchString" class="form-control border-0 shadow-sm rounded-start-pill px-3" placeholder="Ara..." value="@ViewBag.SearchString">
                <button type="submit" class="btn btn-white shadow-sm rounded-end-pill border-0"><i class="fas fa-search text-muted"></i></button>
            </form>

            @* Yeni Butonu *@
            <button class="btn btn-primary rounded-pill px-4 shadow fw-bold" data-bs-toggle="modal" data-bs-target="#createGroupModal">
                <i class="fas fa-plus me-1"></i> Yeni
            </button>
        </div>
    </div>

    @* --- KLASÖR GRİDİ --- *@
    <div class="row g-4" id="folderGrid">
        @foreach (var group in Model)
        {
            <div class="col-xl-3 col-lg-4 col-md-6">
                <div class="card h-100 folder-card text-center p-4 shadow-sm @(group.IsSystem ? "is-system" : "")" 
                     data-id="@group.Id" 
                     data-is-system="@group.IsSystem.ToString().ToLower()"
                     onclick="handleFolderClick(this, @group.Id)">
                    
                    @* Checkbox — sistem klasöründe gizli *@
                    @if (!group.IsSystem)
                    {
                        <div class="folder-checkbox-area">
                            <input type="checkbox" class="form-check-input folder-checkbox" 
                                   value="@group.Id" onclick="event.stopPropagation(); toggleSelection(this);">
                        </div>
                    }

                    @* Düzenle Butonu — sistem klasöründe gizli *@
                    @if (!group.IsSystem)
                    {
                        <div class="folder-edit-area" style="position: absolute; top: 20px; right: 20px; z-index: 10;">
                            <button class="btn btn-sm btn-light border rounded-circle shadow-sm" 
                                    onclick="renameGroup(@group.Id, '@group.GroupName', event)" title="İsmi Değiştir">
                                <i class="fas fa-pen text-secondary small"></i>
                            </button>
                        </div>
                    }
                    else
                    {
                        @* Kilit rozeti *@
                        <div style="position: absolute; top: 16px; right: 16px; z-index: 10;">
                            <span class="system-badge"><i class="fas fa-lock"></i> Sistem</span>
                        </div>
                    }

                    <div class="folder-icon-wrapper mt-2">
                        @if (group.IsSystem)
                        {
                            <i class="fas fa-users folder-icon"></i>
                        }
                        else
                        {
                            <i class="fas fa-folder-open folder-icon"></i>
                        }
                    </div>

                    <h5 class="fw-bold text-dark mb-2">
                        @group.GroupName
                        @if (group.IsSystem)
                        {
                            <i class="fas fa-thumbtack text-primary ms-1 small" title="Sabitlenmiş"></i>
                        }
                    </h5>
                    <span class="badge bg-light text-secondary rounded-pill px-3 py-1 border small">
                        <i class="fas fa-users me-1 small"></i> @(counts.ContainsKey(group.Id) ? counts[group.Id] : 0) Abone
                    </span>
                </div>
            </div>
        }
    </div>

    @* --- SAYFALAMA --- *@
    @if (ViewBag.TotalPages > 1)
    {
        <nav class="mt-5">
            <ul class="pagination justify-content-center">
                @for (int i = 1; i <= ViewBag.TotalPages; i++) {
                    <li class="page-item @(ViewBag.CurrentPage == i ? "active" : "")">
                        <a class="page-link border-0 rounded-pill mx-1 shadow-sm px-3" href="?page=@i&searchString=@ViewBag.SearchString">@i</a>
                    </li>
                }
            </ul>
        </nav>
    }
</div>

@* MODAL AYNEN KALIYOR *@
<div class="modal fade" id="createGroupModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg" style="border-radius: 25px;">
            <div class="modal-header border-0 p-4 pb-0"><h5 class="fw-bold">Yeni Klasör</h5><button type="button" class="btn-close" data-bs-dismiss="modal"></button></div>
            <form asp-action="CreateGroup" method="post">
                <div class="modal-body p-4"><input type="text" name="groupName" class="form-control rounded-pill border-2 px-4 py-2" placeholder="Klasör Adı" required></div>
                <div class="modal-footer border-0 p-4 pt-0"><button type="submit" class="btn btn-primary rounded-pill w-100 fw-bold shadow">Kaydet</button></div>
            </form>
        </div>
    </div>
</div>

@* MODAL: Abone Seç ve Ekle *@
<div class="modal fade" id="addMemberToFoldersModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered modal-dialog-scrollable">
        <div class="modal-content border-0 shadow-lg" style="border-radius: 25px;">
            <div class="modal-header border-0 p-4 pb-0">
                <div>
                    <h5 class="fw-bold mb-1">Klasörlere Abone Ekle</h5>
                    <small class="text-muted">Seçili <span id="targetFolderCountBadge" class="fw-bold text-primary">0</span> klasöre eklenecek aboneleri seçin.</small>
                </div>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-4">
                @* Arama ve Filtre *@
                <div class="input-group mb-3">
                    <span class="input-group-text bg-light border-0"><i class="fas fa-search text-muted"></i></span>
                    <input type="text" id="modalSearchInput" class="form-control bg-light border-0" placeholder="İsim veya E-posta ara..." onkeyup="delaySearchModal()">
                </div>

                @* Tablo *@
                <div class="table-responsive border rounded-4">
                    <table class="table table-hover align-middle mb-0" id="modalSubscribersTable">
                        <thead class="table-light">
                            <tr>
                                <th class="ps-4" width="40"><input type="checkbox" id="modalSelectAll" class="form-check-input"></th>
                                <th>Abone Bilgisi</th>
                                <th>E-Posta</th>
                            </tr>
                        </thead>
                        <tbody id="modalSubscribersBody">
                            <tr><td colspan="3" class="text-center py-4 text-muted">Yükleniyor...</td></tr>
                        </tbody>
                    </table>
                </div>

                @* Sayfalama *@
                <nav class="mt-3 d-flex justify-content-center">
                    <ul class="pagination pagination-sm mb-0" id="modalPagination"></ul>
                </nav>
            </div>
            <div class="modal-footer border-0 p-4 pt-0">
                <span class="me-auto text-muted small"><span id="modalSelectedCount">0</span> abone seçildi</span>
                <button type="button" class="btn btn-light rounded-pill px-4 fw-bold" data-bs-dismiss="modal">İptal</button>
                <button type="button" class="btn btn-primary rounded-pill px-4 fw-bold shadow" onclick="submitModalSelection()">
                    <i class="fas fa-plus me-1"></i> Seçilenlere Ekle
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        const FOLDER_STORAGE_KEY = "selected_folder_ids";

        $(document).ready(function() {
            // Sayfa yüklenince eski seçimleri temizle (toplu işlem alanı sadece aktif seçimde çıksın)
            clearAllSelections();
        });

        // 🚀 AKILLI TIKLAMA MANTIĞI
        function handleFolderClick(cardElement, groupId) {
            const selectedIds = getStoredFolderIds();

            if (selectedIds.length > 0) {
                // Eğer hafızada seçili biri varsa, her tıklama seçim modundadır
                const checkbox = cardElement.querySelector('.folder-checkbox');
                checkbox.checked = !checkbox.checked;
                toggleSelection(checkbox);
            } else {
                // Hiç seçim yoksa dosyanın içine girer
                location.href = '/Subscriber/GroupDetails?groupId=' + groupId;
            }
        }

        // Seçim ve Hafıza Yönetimi
        function toggleSelection(checkbox) {
            const id = checkbox.value;
            const card = checkbox.closest('.folder-card');
            
            // Sistem klasörü seçilemez
            if (card.dataset.isSystem === 'true') {
                checkbox.checked = false;
                return;
            }

            let selectedIds = getStoredFolderIds();

            if (checkbox.checked) {
                selectedIds.push(id);
                card.classList.add('is-selected');
            } else {
                selectedIds = selectedIds.filter(item => item !== id);
                card.classList.remove('is-selected');
            }

            saveStoredFolderIds(selectedIds);
            updateFolderUI();
        }

        function getStoredFolderIds() {
            const data = sessionStorage.getItem(FOLDER_STORAGE_KEY);
            return data ? JSON.parse(data) : [];
        }

        function saveStoredFolderIds(ids) {
            const uniqueIds = [...new Set(ids)];
            sessionStorage.setItem(FOLDER_STORAGE_KEY, JSON.stringify(uniqueIds));
        }

        function restoreFolderSelection() {
            const storedIds = getStoredFolderIds();
            $('.folder-checkbox').each(function() {
                if (storedIds.includes($(this).val())) {
                    $(this).prop('checked', true);
                    $(this).closest('.folder-card').addClass('is-selected');
                }
            });
            updateFolderUI();
        }

        function updateFolderUI() {
            const count = getStoredFolderIds().length;
            const header = document.getElementById('bulkActionHeader');
            const countSpan = document.getElementById('selectedFolderCount');

            if (count > 0) {
                header.classList.remove('d-none');
                header.classList.add('d-flex');
                countSpan.innerText = count;
            } else {
                header.classList.remove('d-flex');
                header.classList.add('d-none');
            }
        }

        function clearAllSelections() {
            sessionStorage.removeItem(FOLDER_STORAGE_KEY);
            $('.folder-checkbox').prop('checked', false);
            $('.folder-card').removeClass('is-selected');
            updateFolderUI();
        }

        function bulkDeleteGroups() {
            const ids = getStoredFolderIds();
            Swal.fire({
                title: 'Seçilen Klasörleri Sil?',
                text: `${ids.length} adet klasör silinecek. Not: İçindeki aboneler silinmez.`,
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#d33',
                confirmButtonText: 'Evet, Sil'
            }).then((res) => {
                if (res.isConfirmed) {
                    $.post('/Subscriber/BulkDeleteGroups', { groupIds: ids }, function() {
                        clearAllSelections();
                        location.reload();
                    });
                }
            });
        }

        // --- ABONE EKLEME MODAL İŞLEMLERİ (YENİ) ---
        var modalSelectedSubscriberIds = new Set();
        var modalCurrentPage = 1;
        var modalSearchTimeout;

        $(document).ready(function() {
            // Modal Checkbox Değişimleri (Delegation ile)
            $(document).on('change', '.modal-sub-checkbox', function() {
                var id = String($(this).val());
                if (this.checked) modalSelectedSubscriberIds.add(id);
                else modalSelectedSubscriberIds.delete(id);
                updateModalUI();
            });

            $('#modalSelectAll').on('change', function() {
                var isChecked = this.checked;
                $('.modal-sub-checkbox').each(function() {
                    $(this).prop('checked', isChecked);
                    var id = String($(this).val());
                    if (isChecked) modalSelectedSubscriberIds.add(id);
                    else modalSelectedSubscriberIds.delete(id);
                });
                updateModalUI();
            });
        });

        function openAddMemberModal() {
            var folderCount = getStoredFolderIds().length;
            if (folderCount === 0) return;

            $('#targetFolderCountBadge').text(folderCount);
            modalSelectedSubscriberIds.clear();
            modalCurrentPage = 1;
            $('#modalSearchInput').val('');
            updateModalUI();
            
            new bootstrap.Modal(document.getElementById('addMemberToFoldersModal')).show();
            loadSubscribersForModal(1);
        }

        function delaySearchModal() {
            clearTimeout(modalSearchTimeout);
            modalSearchTimeout = setTimeout(() => {
                modalCurrentPage = 1;
                loadSubscribersForModal(1);
            }, 500);
        }

        function loadSubscribersForModal(page) {
            modalCurrentPage = page;
            var search = $('#modalSearchInput').val();

            $('#modalSubscribersBody').html('<tr><td colspan="3" class="text-center py-4"><div class="spinner-border text-primary" role="status"></div></td></tr>');

            $.get('/Subscriber/SearchSubscribersIndexAjax', { searchString: search, page: page }, function(res) {
                var tbody = $('#modalSubscribersBody');
                tbody.empty();

                if (res.data.length === 0) {
                    tbody.html('<tr><td colspan="3" class="text-center py-4 text-muted">Sonuç bulunamadı.</td></tr>');
                    $('#modalPagination').empty();
                    return;
                }

                res.data.forEach(function(sub) {
                    var isChecked = modalSelectedSubscriberIds.has(String(sub.id));
                    var row = `
                        <tr style="cursor:pointer" onclick="$(this).find('.modal-sub-checkbox').click()">
                            <td class="ps-4" onclick="event.stopPropagation()">
                                <input type="checkbox" class="form-check-input modal-sub-checkbox" value="${sub.id}" ${isChecked ? 'checked' : ''}>
                            </td>
                            <td><div class="fw-bold text-dark">${sub.firstName || ''} ${sub.lastName || ''}</div></td>
                            <td><span class="text-muted small">${sub.email}</span></td>
                        </tr>
                    `;
                    tbody.append(row);
                });

                renderModalPagination(res.totalCount, res.page, res.pageSize);
                updateModalSelectAllState();
            });
        }

        function renderModalPagination(totalCount, currentPage, pageSize) {
            var totalPages = Math.ceil(totalCount / pageSize);
            var pagination = $('#modalPagination');
            pagination.empty();

            if (totalPages <= 1) return;

            pagination.append(`<li class="page-item ${currentPage === 1 ? 'disabled' : ''}">
                <button class="page-link rounded-pill border-0 mx-1" onclick="loadSubscribersForModal(${currentPage - 1})"><i class="fas fa-chevron-left"></i></button></li>`);

            pagination.append(`<li class="page-item active"><span class="page-link rounded-pill border-0 mx-1">${currentPage} / ${totalPages}</span></li>`);

            pagination.append(`<li class="page-item ${currentPage === totalPages ? 'disabled' : ''}">
                <button class="page-link rounded-pill border-0 mx-1" onclick="loadSubscribersForModal(${currentPage + 1})"><i class="fas fa-chevron-right"></i></button></li>`);
        }

        function updateModalUI() {
            $('#modalSelectedCount').text(modalSelectedSubscriberIds.size);
        }

        function updateModalSelectAllState() {
            var total = $('.modal-sub-checkbox').length;
            var checked = $('.modal-sub-checkbox:checked').length;
            $('#modalSelectAll').prop('checked', total > 0 && total === checked);
        }

        function submitModalSelection() {
            var subIds = Array.from(modalSelectedSubscriberIds);
            var grpIds = getStoredFolderIds();

            if (subIds.length === 0) { Swal.fire({ icon: 'warning', title: 'Uyarı', text: 'Lütfen en az bir abone seçin.' }); return; }
            if (grpIds.length === 0) { Swal.fire({ icon: 'warning', title: 'Uyarı', text: 'Hedef klasör seçimi kaybolmuş.' }); return; }

            // Loading
            var btn = event.target;
            var originalText = btn.innerHTML;
            btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Ekleniyor...';
            btn.disabled = true;

            $.post('/Subscriber/BulkAddToGroup', { subscriberIds: subIds, groupIds: grpIds }, function(res) {
                if (res.success) {
                    Swal.fire({ icon: 'success', title: 'Başarılı', text: res.message, timer: 1500, showConfirmButton: false })
                    .then(() => {
                        clearAllSelections();
                        location.reload();
                    });
                } else {
                    Swal.fire({ icon: 'error', title: 'Hata', text: res.message });
                    btn.innerHTML = originalText;
                    btn.disabled = false;
                }
            });
        }

        // --- KLASÖR İSİM DEĞİŞTİRME ---
        function renameGroup(id, currentName, event) {
            event.stopPropagation(); // Kart tıklamasını engelle
            Swal.fire({
                title: 'Klasör İsmini Değiştir',
                input: 'text',
                inputValue: currentName,
                showCancelButton: true,
                confirmButtonText: 'Kaydet',
                cancelButtonText: 'İptal',
                confirmButtonColor: '#0d6efd',
                inputValidator: (value) => {
                    if (!value) return 'Bir isim yazmalısınız!'
                }
            }).then((result) => {
                if (result.isConfirmed) {
                    $.post('/Subscriber/RenameGroup', { id: id, newName: result.value }, function(res) {
                         if(res.success) {
                             Swal.fire({ icon: 'success', title: 'Başarılı', text: 'Klasör ismi değiştirildi.', timer: 1000, showConfirmButton: false })
                             .then(() => location.reload());
                         }
                         else {
                             Swal.fire('Hata', res.message, 'error');
                         }
                    });
                }
            });
        }
    </script>
}