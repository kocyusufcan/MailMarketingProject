@model List<MailMarketing.Entity.Template>
@{
    ViewData["Title"] = "Şablonlarım";
}

<style>
    /* 📱 iOS Modern UI Çizgileri */
    body { background-color: #f2f2f7; font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif; }

    .ios-page-header { padding: 30px 0 20px 0; }
    .ios-main-title { font-size: 2.2rem; font-weight: 800; color: #000; letter-spacing: -1px; }
    .ios-subtitle { color: #8e8e93; font-weight: 500; font-size: 1rem; }

    /* Buton Tasarımları */
    .btn-ios-add {
        background-color: #007aff; color: #fff; border-radius: 14px;
        padding: 10px 20px; font-weight: 600; border: none; transition: all 0.2s;
        box-shadow: 0 4px 12px rgba(0, 122, 255, 0.3);
    }
    .btn-ios-add:hover { background-color: #0062cc; transform: scale(1.02); color: #fff; }

    .btn-ios-word {
        background-color: #fff; color: #007aff; border: 1.5px solid #007aff;
        border-radius: 14px; padding: 9px 20px; font-weight: 600; transition: all 0.2s;
    }
    .btn-ios-word:hover { background-color: #f2f8ff; transform: scale(1.02); }

    /* 🗂️ Şablon Kart Tasarımı */
    .template-card {
        background: #fff; border-radius: 22px; border: 2px solid transparent;
        box-shadow: 0 5px 15px rgba(0,0,0,0.04); transition: all 0.3s ease;
        overflow: hidden; height: 100%; position: relative; cursor: pointer;
    }
    .template-card:hover { transform: translateY(-5px); box-shadow: 0 10px 25px rgba(0,0,0,0.08); }
    
    /* 🔵 SEÇİLEN KARTIN GÖRSEL EFEKTİ */
    .template-card.is-selected {
        border-color: #007aff !important;
        background-color: #f0f7ff !important;
    }

    .card-preview-area {
        height: 120px; background: linear-gradient(135deg, #f5f7fa 0%, #e4e7eb 100%);
        display: flex; align-items: center; justify-content: center; position: relative;
    }
    .card-preview-area i { font-size: 3rem; color: #c7c7cc; }
    
    .status-dot {
        position: absolute; top: 15px; right: 15px; padding: 5px 12px;
        border-radius: 20px; font-size: 0.75rem; font-weight: 700;
        text-transform: uppercase; cursor: pointer; text-decoration: none; z-index: 10;
    }
    .status-active { background: #e1f5fe; color: #0288d1; }
    .status-passive { background: #ffebee; color: #d32f2f; }

    .template-info { padding: 20px; }
    .template-name { font-weight: 700; font-size: 1.2rem; color: #1c1c1e; margin-bottom: 5px; }

    /* Alt Butonlar */
    .ios-card-footer { padding: 15px 20px; background: #fafafa; border-top: 1px solid #f2f2f7; display: flex; gap: 10px; }
    .btn-ios-card { flex: 1; border-radius: 12px; padding: 10px; font-weight: 600; font-size: 0.9rem; text-align: center; text-decoration: none; }
    .btn-preview { background: #e5e5ea; color: #1c1c1e; }
    .btn-send { background: #34c759; color: #fff; }

    /* Checkbox Stil */
    .template-checkbox {
        position: absolute; top: 15px; left: 50px; width: 20px; height: 20px;
        cursor: pointer; z-index: 15; accent-color: #007aff;
    }

    .more-btn {
        position: absolute; top: 10px; left: 10px; background: rgba(255,255,255,0.8);
        border-radius: 50%; width: 32px; height: 32px; display: flex;
        align-items: center; justify-content: center; color: #8e8e93; z-index: 15;
    }

    /* Sayfalama Stili */
    .page-link-ios {
        width: 40px; height: 40px; border-radius: 50% !important;
        display: flex; align-items: center; justify-content: center;
        font-weight: 600; border: none; background: #fff; color: #000;
        box-shadow: 0 2px 8px rgba(0,0,0,0.05); margin: 0 3px;
    }
    .page-item.active .page-link-ios { background: #007aff; color: #fff; }
</style>

<div class="container pb-5">
    @* 1️⃣ Üst Başlık ve Buton Grubu *@
    <div class="ios-page-header d-flex justify-content-between align-items-end flex-wrap gap-3">
        <div>
            <p class="ios-subtitle mb-1">E-Posta Pazarlama</p>
            <h1 class="ios-main-title">Şablonlarım</h1>
        </div>
        <div class="d-flex gap-2 align-items-center">
            <button type="button" id="btnBulkDelete" class="btn btn-danger btn-sm rounded-pill px-3 shadow-sm" style="display:none;" onclick="confirmBulkAction('delete')">Sil (<span class="selCount">0</span>)</button>
            <button type="button" id="btnBulkActivate" class="btn btn-success btn-sm rounded-pill px-3 shadow-sm text-white" style="display:none;" onclick="confirmBulkAction('activate')">Aktif Et</button>
            <button type="button" id="btnBulkDeactivate" class="btn btn-warning btn-sm rounded-pill px-3 shadow-sm text-white" style="display:none;" onclick="confirmBulkAction('deactivate')">Pasif Et</button>

            @* 🔥 WORD'DEN AKTAR BUTONU *@
            <button type="button" class="btn btn-ios-word shadow-sm" data-bs-toggle="modal" data-bs-target="#importWordModal">
                <i class="fas fa-file-word me-1"></i> Word'den Aktar
            </button>
            
            <a href="/Template/Create" class="btn btn-ios-add shadow-sm">
                <i class="fas fa-plus me-2"></i> Yeni Şablon
            </a>
        </div>
    </div>

    @* 2️⃣ Filtreleme Paneli *@
    <div class="card border-0 shadow-sm mb-4 p-3 bg-white" style="border-radius: 18px;">
        <form method="get" asp-action="Index" class="row g-2 align-items-center">
            <div class="col-md-6">
                <input type="text" name="searchString" class="form-control border-0 bg-light rounded-pill px-4" placeholder="Şablon adı ile ara..." value="@ViewBag.SearchString">
            </div>
            <div class="col-md-3">
                <select name="status" class="form-select border-0 bg-light rounded-pill px-3">
                    <option value="">Tüm Durumlar</option>
                    <option value="active" selected='@(ViewBag.CurrentStatus == "active")'>Aktif Şablonlar</option>
                    <option value="passive" selected='@(ViewBag.CurrentStatus == "passive")'>Pasif Şablonlar</option>
                </select>
            </div>
            <div class="col-md-3">
                <button type="submit" class="btn btn-primary w-100 rounded-pill fw-bold shadow-sm">Filtrele</button>
            </div>
        </form>
    </div>

    @* 3️⃣ Şablon Kartları Grid *@
    <form id="bulkActionForm" method="post">
        <div class="row g-4">
            @foreach (var item in Model)
            {
                <div class="col-lg-4 col-md-6">
                    <div class="template-card" data-id="@item.Id">
                        <div class="card-preview-area">
                            <input type="checkbox" name="selectedIds" value="@item.Id" class="form-check-input template-checkbox shadow-sm">

                            <div class="dropdown">
                                <a href="#" class="more-btn" data-bs-toggle="dropdown"><i class="fas fa-ellipsis-h"></i></a>
                                <ul class="dropdown-menu shadow border-0 rounded-4">
                                    <li><a class="dropdown-item py-2" href="/Template/Edit/@item.Id"><i class="fas fa-edit me-2 text-primary"></i> Düzenle</a></li>
                                    <li><a class="dropdown-item py-2 text-danger" href="javascript:void(0)" onclick="confirmDeleteTemplate(@item.Id)"><i class="fas fa-trash-alt me-2"></i> Sil</a></li>
                                </ul>
                            </div>
                            
                            <i class="fas fa-envelope-open-text"></i>
                            <a href="@Url.Action("ToggleStatus", "Template", new { id = item.Id })" class="status-dot @(item.IsActive ? "status-active" : "status-passive")">
                                @(item.IsActive ? "Aktif" : "Pasif")
                            </a>
                        </div>

                        <div class="template-info">
                            <div class="template-name text-truncate">@item.Title</div>
                            <div class="template-meta">
                                <span><i class="far fa-calendar-alt me-1"></i> @item.CreatedDate.ToString("dd.MM.yyyy")</span>
                            </div>
                        </div>

                        <div class="ios-card-footer">
                            <a href="javascript:void(0)" onclick="openPreview(@item.Id)" class="btn-ios-card btn-preview">Önizleme</a>
                            <a href="/Template/Send/@item.Id" class="btn-ios-card btn-send @(item.IsActive ? "" : "disabled opacity-50")">
                                Gönder <i class="fas fa-paper-plane ms-1"></i>
                            </a>
                        </div>
                    </div>
                </div>
            }
        </div>
    </form>

    @* 4️⃣ Akıllı Sayfalama *@
    @if (ViewBag.TotalPages > 1)
    {
        <nav class="mt-5 mb-4">
            <ul class="pagination justify-content-center gap-1">
                @{ int cur = ViewBag.CurrentPage; int total = ViewBag.TotalPages; int gap = 2; }
                <li class="page-item @(cur == 1 ? "disabled" : "")">
                    <a class="page-link page-link-ios" href="@Url.Action("Index", new { page = cur - 1, searchString = ViewBag.SearchString, status = ViewBag.CurrentStatus })"><i class="fas fa-chevron-left small"></i></a>
                </li>
                @for (int i = 1; i <= total; i++) {
                     @if (i == 1 || i == total || (i >= cur - gap && i <= cur + gap)) {
                        <li class="page-item @(i == cur ? "active" : "")">
                            <a class="page-link page-link-ios @(i == cur ? "bg-primary text-white" : "text-dark bg-white")" href="@Url.Action("Index", new { page = i, searchString = ViewBag.SearchString, status = ViewBag.CurrentStatus })">@i</a>
                        </li>
                     } else if (i == cur - gap - 1 || i == cur + gap + 1) {
                        <li class="page-item disabled"><span class="page-link border-0 bg-transparent text-muted">...</span></li>
                     }
                }
                <li class="page-item @(cur == total ? "disabled" : "")">
                    <a class="page-link page-link-ios" href="@Url.Action("Index", new { page = cur + 1, searchString = ViewBag.SearchString, status = ViewBag.CurrentStatus })"><i class="fas fa-chevron-right small"></i></a>
                </li>
            </ul>
        </nav>
    }
</div>

@* --- 📄 WORD IMPORT MODAL --- *@
<div class="modal fade" id="importWordModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg" style="border-radius: 25px;">
            <div class="modal-header border-0 pb-0 px-4 pt-4">
                <h5 class="fw-bold"><i class="fas fa-file-import text-primary me-2"></i>Word'den Şablon Aktar</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form asp-action="ImportFromWord" method="post" enctype="multipart/form-data">
                <div class="modal-body p-4">
                    <p class="text-muted small mb-3">Word (.docx) dosyanızdaki içerikler otomatik olarak e-posta şablonuna dönüştürülür.</p>
                    <div class="bg-light p-4 rounded-4 border-2 border-dashed text-center" style="border-style: dashed !important; border-color: #007aff !important; border-width: 2px !important;">
                        <i class="fas fa-cloud-upload-alt fa-3x text-primary mb-2 opacity-50"></i>
                        <input type="file" name="wordFile" class="form-control" accept=".docx" required>
                        <div class="mt-2 extra-small text-muted">Sadece .docx dosyaları desteklenir.</div>
                    </div>
                </div>
                <div class="modal-footer border-0 p-4 pt-0">
                    <button type="button" class="btn btn-light rounded-pill px-4" data-bs-dismiss="modal">Vazgeç</button>
                    <button type="submit" class="btn btn-primary rounded-pill px-4 shadow-sm fw-bold">Dönüştür ve Düzenle</button>
                </div>
            </form>
        </div>
    </div>
</div>

@* Önizleme Modalı *@
<div class="modal fade" id="previewModal" tabindex="-1">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg" style="border-radius: 25px;">
            <div class="modal-header border-0 pb-0 px-4 pt-4">
                <h5 class="fw-bold" id="modalTitle">Şablon Önizleme</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-4">
                <div id="modalContent" class="border rounded-4 p-3 bg-light" style="max-height: 500px; overflow-y: auto;"></div>
            </div>
            <div class="modal-footer border-0 p-4">
                <button type="button" class="btn btn-light rounded-pill px-4" data-bs-dismiss="modal">Kapat</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        $(document).ready(function() {
            // 🔥 KARTA TIKLAYINCA SEÇME (Power User UX)
            $('.template-card').on('click', function(e) {
                if ($(e.target).closest('a, button, .dropdown-menu, .status-dot, .template-checkbox').length) return;
                const checkbox = $(this).find('.template-checkbox');
                checkbox.prop('checked', !checkbox.prop('checked')).trigger('change');
            });

            // ⚙️ SEÇİM DEĞİŞİKLİĞİ
            $(document).on('change', '.template-checkbox', function() {
                const count = $('.template-checkbox:checked').length;
                const display = count > 0 ? 'inline-block' : 'none';
                $('#btnBulkDelete, #btnBulkActivate, #btnBulkDeactivate').css('display', display);
                $('.selCount').text(count);
                $(this).closest('.template-card').toggleClass('is-selected', this.checked);
            });
        });

        // 🚀 AKILLI TOPLU İŞLEM
        function confirmBulkAction(actionType) {
            let config = { title: 'Emin misiniz?', confirmButtonText: 'Evet, Uygula!', showCancelButton: true, cancelButtonText: 'Vazgeç' };
            const form = document.getElementById('bulkActionForm');
            if (actionType === 'delete') {
                config.text = "Seçilen şablonlar kalıcı olarak silinecek!"; config.icon = 'warning'; config.confirmButtonColor = '#d33';
                form.action = '/Template/BulkDelete';
            } else if (actionType === 'activate') {
                config.text = "Şablonlar AKTİF hale getirilecek."; config.icon = 'question'; config.confirmButtonColor = '#34c759';
                form.action = '/Template/BulkActivate';
            } else {
                config.text = "Şablonlar PASİF hale getirilecek."; config.icon = 'warning'; config.confirmButtonColor = '#f59e0b';
                form.action = '/Template/BulkDeactivate';
            }
            Swal.fire(config).then((result) => { if (result.isConfirmed) form.submit(); });
        }

        function openPreview(id) {
            $.get('/Template/GetPreview/' + id, function(data) {
                $('#modalTitle').text(data.title); $('#modalContent').html(data.content);
                new bootstrap.Modal(document.getElementById('previewModal')).show();
            });
        }

        function confirmDeleteTemplate(id) {
            Swal.fire({ title: 'Emin misiniz?', text: "Bu şablon silinecek.", icon: 'warning', showCancelButton: true, confirmButtonColor: '#d33', confirmButtonText: 'Sil' })
            .then((r) => { if (r.isConfirmed) window.location.href = '/Template/Delete/' + id; });
        }
    </script>
}